{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Information collected from the contact/quote form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the customer" },
        "email": { "type": "string", "format": "email", "description": "Customer email address" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "serviceType": { "type": "string", "description": "Type of service requested (e.g., Towing, Collision, Body Work)" },
        "message": { "type": "string", "description": "Additional details from the customer" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was created" }
      },
      "required": ["name", "phone", "serviceType", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of customer leads and inquiries"
    }
  }
}
